# Optional — copy to .env to override docker-compose defaults.
# Not required for Docker; docker compose up --build works out of the box.

POSTGRES_DB=url_shortener
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://user:password@db:5432/url_shortener
PORT=8080
BASE_URL=http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
